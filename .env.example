# ==============================================================================
# Variables de entorno — BancoLite
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
# ==============================================================================

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────
POSTGRES_USER=banco_user
POSTGRES_PASSWORD=banco_password
POSTGRES_DB=banco_lite
# Host de la base de datos: `db` dentro de Docker Compose, `localhost` en local
DB_HOST=db
DB_PORT=5432

# ── Flask (backend) ───────────────────────────────────────────────────────
# Entorno de ejecución: development | production
FLASK_ENV=development
# Modo debug: 1 (activado) | 0 (desactivado). Desactívalo en producción.
FLASK_DEBUG=1
